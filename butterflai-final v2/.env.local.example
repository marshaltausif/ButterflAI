# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run_openssl_rand_base64_32

# ── Google OAuth + Drive ──────────────────────────────────────────────────────
# console.cloud.google.com → enable Google Drive API → OAuth 2.0 credentials
# Authorized redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# ── AI Providers (pick at least one) ─────────────────────────────────────────
# Gemini 1.5 Flash — FREE: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxx
# Groq Llama 3.3 — FREE: https://console.groq.com
GROQ_API_KEY=gsk_xxxx
# Claude Haiku — lowest cost: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Dataset credentials ───────────────────────────────────────────────────────
# Kaggle — https://kaggle.com/settings → API → Create token
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_kaggle_api_key
# HuggingFace (optional — only needed for gated datasets)
HF_TOKEN=hf_xxxx

# ── Training backends (chain: Modal → Replicate → local subprocess) ───────────

# BACKEND 1: Modal.com T4 GPU (preferred — full pipeline)
# modal token new  →  copies to ~/.modal.toml, also paste here
MODAL_TOKEN_ID=ak-xxxx
MODAL_TOKEN_SECRET=xxxx
# Name of your deployed Modal app (default: butterflai)
MODAL_APP_NAME=butterflai

# BACKEND 2: Replicate.com (pay-per-second, no deploy needed — auto-fallback)
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxx
# Optional: pin to a specific model version
# REPLICATE_MODEL_VERSION=stability-ai/sdxl:39ed52f2...

# BACKEND 3: Local subprocess (always available — CPU only, dev/testing)
# No config needed — runs python3 train.py on the API server itself
