# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_here

# ── Google OAuth + Drive ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# ── AI Providers (fallback keys) ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...  # Optional - users can provide their own
GROQ_API_KEY=gsk_...     # Optional - users can provide their own
ANTHROPIC_API_KEY=sk-ant-...  # Optional - users can provide their own

# ── Modal GPU ─────────────────────────────────────────────────────────────────
MODAL_TOKEN_ID=ak-xxxx
MODAL_TOKEN_SECRET=xxxx

# ── Kaggle API (optional - users provide their own) ──────────────────────────
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_key