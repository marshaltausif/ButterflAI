# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_here

# ── Google OAuth + Drive ──────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Drive API, Google People API
# Authorized redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# ── Supabase ──────────────────────────────────────────────────────────────────
# https://supabase.com → New project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# ── AI Providers (all have generous free tiers) ───────────────────────────────
# Gemini Flash — FREE: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxx
# Groq Llama 3 — FREE: https://console.groq.com
GROQ_API_KEY=gsk_xxxx
# Claude Haiku — paid but cheapest tier: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Modal GPU ─────────────────────────────────────────────────────────────────
# https://modal.com/settings → API Tokens
MODAL_TOKEN_ID=ak-xxxx
MODAL_TOKEN_SECRET=xxxx
